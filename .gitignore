# Per-user runtime state — NEVER commit
.credentials.json
rolling_memory.db*
history.jsonl
settings.json
settings.local.json
settings.json.bak*
CLAUDE.md.backup*
CLAUDE.md.phase*
.booster-manifest.json
.booster-install.lock

# Per-user directories (never slurp from ~/.claude)
backups/
cache/
chrome/
debug/
downloads/
file-history/
ide/
image-cache/
logs/
paste-cache/
plans/
projects/
scheduled-tasks/
session-env/
sessions/

# Bak variants of anything
*.bak
*.bak_*
*-shm
*-wal

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# OS/editor
.DS_Store
.idea/
.vscode/
*.swp

# Test artifacts
test_home/
/tmp_install/

# SSH keys / secrets (defense in depth)
id_rsa*
id_ed25519*
id_ecdsa*
*.pem
*.key
*.p12
*.pfx
*_secret.*
*.env
.env.local
.env.*.local

# Per-project Claude Code state (if user ever accidentally cp-r's)
.claude/settings.local.json
.claude/CLAUDE.md
.claude/sessions/
.claude/plans/
.claude/paste-cache/

# NOTE: `reports/` is tracked in this working repo (consilium/audit/handover
# history for /start retrieval). The PUBLIC distribution repo
# (github.com/demetrius2017/claude-booster) has its own .gitignore that
# excludes reports/ — the fresh-init push strategy keeps personal content
# out of the public history.

.cache/
