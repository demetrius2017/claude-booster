{
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "MAX_THINKING_TOKENS": "12000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(python3 ~/.claude/scripts/supervisor/supervisor.py *)",
      "Bash(python3 */.claude/scripts/supervisor/supervisor.py *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill",
      "ToolSearch",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "NotebookEdit",
      "mcp__pal__*",
      "mcp__plugin_context7_context7__*",
      "mcp__chrome-devtools__*",
      "mcp__claude-in-chrome__*",
      "mcp__playwright__*"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rm)",
      "Bash(unlink *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(* && rm *)",
      "Bash(* || rm *)",
      "Bash(* | xargs rm *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(kubectl delete*)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/memory_session_start.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/phase_prompt_inject.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/verify_gate.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/require_task.py",
            "source": "booster@${BOOSTER_VERSION}"
          },
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/phase_gate.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/approval_counter.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/memory_post_tool.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/require_evidence.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/preserve_plan_context.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${CLAUDE_HOME}/scripts/memory_session_end.py",
            "source": "booster@${BOOSTER_VERSION}"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "skipAutoPermissionPrompt": false,
  "_booster": {
    "version": "${BOOSTER_VERSION}",
    "installed_at": "${INSTALLED_AT}"
  }
}
